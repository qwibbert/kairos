		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/chroma-js": "^3.1.2",
		"@types/culori": "^4.0.1",
		"@types/luxon": "^3.7.2",
		"@zerodevx/svelte-toast": "^0.9.6",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
